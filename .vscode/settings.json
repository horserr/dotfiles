{
  // "editor.folding": false,
  // "editor.glyphMargin": false,
  // "editor.lineNumbers": "interval",

  // catppuccin-icons list: https://github.com/catppuccin/vscode-icons/tree/main/icons/mocha
  // Files with the `spec.ts` extension will have the `typescript-test` icon.
  "catppuccin-icons.associations.extensions": {
    "extension-list.yaml": "juce",
    "json.tmpl": "json",
    "jsonc.tmpl": "jsonc",
    "properties.tmpl": "properties",
    "ps1.tmpl": "powershell",
    "toml.tmpl": "toml"
  },
  // Files with the name `vite.config.ts` will have the `vite` icon.
  "catppuccin-icons.associations.files": {
    ".chezmoi.toml.tmpl": "api-blueprint",
    ".chezmoiignore": "gleam",
    ".chezmoiroot": "rojo",
    "alias": "ember",
    "alias.ps1": "ember",
    "config": "config",
    "dot_ideavimrc": "vim",
    "dot_vimrc": "vim",
    "fish_plugins": "juce",
    "Microsoft.PowerShell_profile.ps1": "codeowners",
    "settings.json": "cucumber",
    "tasks.json": "midi",
    "winapps.jsonc": "juce",
    "windows-terminal.jsonc": "vhs"
  },
  // Folders with the name `typings/` will have the `folder_types` icon.
  "catppuccin-icons.associations.folders": {
    ".chezmoidata": "folder_database",
    ".chezmoiexternals": "folder_include",
    ".chezmoiscripts": "folder_scripts",
    ".chezmoitemplates": "folder_lib",
    "bells": "folder_audio",
    "dot_cargo": "rust-config",
    "dot_cloud-init": "folder_azure-pipelines",
    "dot_config": "folder_drizzle-orm",
    "dot_docker": "folder_docker",
    "dot_ssh": "folder_security",
    "dot_vim": "vim",
    "dot_vscode-server": "folder_vscode",
    "fish": "folder_roblox",
    "gh": "folder_github",
    "git": "folder_git",
    "home": "folder_admin",
    "lazydocker": "docker",
    "mousemaster": "folder_workflows",
    "pixel-shaders": "shader",
    "powershell": "folder_admin",
    "refs": "folder_storybook",
    "ssh": "esbuild",
    "start": "folder_utils",
    "tmux": "vanilla-extract",
    "uv": "uv",
    "vscode": "folder_vscode",
    "yazi": "wally",
    "zellij": "tauri"
  },
  // Files with the language type `typescriptreact` will have the `typescript-react` icon.
  "catppuccin-icons.associations.languages": {
    "ssh_config": "wrangler"
  },
  "files.associations": {
    ".chezmoiattributes": "plaintext",
    ".chezmoiignore": "gitignore",
    ".gitattributes": "plaintext",
    "*.json.tmpl": "json",
    "*.jsonc.tmpl": "jsonc",
    "*.properties.tmpl": "properties",
    "*.ps1.tmpl": "powershell",
    "*.toml.tmpl": "toml",
    "dot_bashrc": "shellscript",
    "dot_gitconfig": "ini",
    "dot_ideavimrc": "Vimscript",
    "dot_inputrc": "shellscript",
    "dot_vimrc": "Vimscript"
  },
  "files.readonlyInclude": {
    "refs/vscode-commands.txt": true,
    "refs/when-clause-sample.json": true
  },
  "saveEditorLayout.list": [],
  "json.validate.enable": true,
  "json.schemaDownload.enable": false,
  "json.schemas": [
    // user settings
    {
      "fileMatch": [
        "**/vscode/settings/*.jsonc.tmpl",
        "**/vscode/settings/*.jsonc"
      ],
      "url": "vscode://schemas/settings/user"
    },
    // todo language specific settings
    {
      "fileMatch": [
        "**/vscode/settings/l-*.jsonc.tmpl",
        "**/vscode/settings/l-*.jsonc"
      ],
      "url": "vscode://schemas/settings/resourceLanguage"
    },
    // language specific sippets
    {
      "fileMatch": ["**/vscode/snippets/*.json"],
      "url": "vscode://schemas/snippets"
    },
    // keybindings
    {
      "fileMatch": [
        "**/vscode/keybindings/*.jsonc",
        "**/vscode/keybindings/*.jsonc.tmpl"
      ],
      "url": "vscode://schemas/keybindings"
    },
    // global snippets
    {
      "fileMatch": ["*.code-snippets"],
      "url": "vscode://schemas/global-snippets"
    },
    // tasks
    {
      "fileMatch": ["**/vscode/tasks.json"],
      "url": "vscode://schemas/tasks"
    }
  ],
  "workbench.diffEditorAssociations": {
    "*.md": "vscode.markdown.preview.editor"
  },
  // workspace tab label customization
  "workbench.editor.customLabels.patterns": {
    "*/.vscode/**": "${filename}(main).${extname}",
    "**/git/**": "${filename}(git)",
    "**/vscode/*.json*": "${filename}(vsc)",
    "**/vscode/*/**/*.json*": "${filename}(${dirname})"
  },
  "workbench.editor.showTabs": "multiple",
  "workbench.editorAssociations": {
    "*.copilotmd": "vscode.markdown.preview.editor"
  },
  "git.blame.editorDecoration.enabled": false,
  // vspacecode dynamic workspace integratiion
  "vspacecode.bindingOverrides": [
    {
      "keys": ["/", "/"],
      "name": "+Search with options",
      "type": "bindings",
      "bindings": [
        // v vscode
        {
          "key": "v",
          "name": "search in vscode folder",
          "type": "command",
          "command": "search.action.openNewEditor",
          "args": {
            // support varialbe substitution
            "query": "",
            "triggerSearch": true,
            "focusResults": true,
            "location": "reuse", // reuse or new

            "isRegexp": false,
            "isCaseSensitive": false,
            "matchWholeWord": false,

            "preserveCase": false,
            "contextLines": 2,

            // support variable substitution
            "filesToInclude": "**/vscode/**",
            // support variable substitution
            "filesToExclude": "",
            "excludeSettingAndIgnoreFiles": true,
            "showIncludesExcludes": false
          }
        },
        // s setting
        {
          "key": "s",
          "name": "search in setting folder",
          "type": "command",
          "command": "search.action.openNewEditor",
          "args": {
            "query": "",
            "triggerSearch": true,
            "focusResults": true,
            "location": "reuse",

            "isRegexp": false,
            "isCaseSensitive": false,
            "matchWholeWord": false,

            "preserveCase": false,
            "contextLines": 2,

            "filesToInclude": "${workspaceFolder}/**/vscode/settings/**",
            "filesToExclude": "",
            "excludeSettingAndIgnoreFiles": true,
            "showIncludesExcludes": false
          }
        },
        // k keybindings
        {
          "key": "k",
          "name": "search in keybindings folder",
          "type": "command",
          "command": "search.action.openNewEditor",
          "args": {
            "query": "",
            "triggerSearch": true,
            "focusResults": true,
            "location": "reuse",

            "isRegexp": false,
            "isCaseSensitive": false,
            "matchWholeWord": false,

            "preserveCase": false,
            "contextLines": 2,

            "filesToInclude": "${workspaceFolder}/**/vscode/keybindings/**",
            "filesToExclude": "",
            "excludeSettingAndIgnoreFiles": true,
            "showIncludesExcludes": false
          }
        }
      ]
    }
  ]
}
