{{- /* code: language=toml */ -}}
{{ if lookPath "vim" }}
[".vim/autoload/plug.vim"]
    type = "file"
    url = "https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim"
    refreshPeriod = "168h"
{{ end -}}

{{ if lookPath "fish" -}}
[".config/fish/functions/fisher.fish"]
    type = "file"
    url = "https://raw.githubusercontent.com/jorgebucaran/fisher/main/functions/fisher.fish"
    executable = true
{{ end -}}

{{ if lookPath "tmux" -}}
[".tmux/plugins/tpm"]
    type = "git-repo"
    url = "https://github.com/tmux-plugins/tpm.git"
    refreshPeriod = "168h"
{{ end -}}

{{ if .isWindows }}
[".config/mousemaster/mousemaster.exe"]
    type = "file"
    url = {{ gitHubLatestReleaseAssetURL "petoncle/mousemaster" "mousemaster.exe" | quote }}
    executable = true
    refreshPeriod = "168h"
{{ end }}
