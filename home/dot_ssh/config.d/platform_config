# code: language=ssh_config
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_github
    PreferredAuthentications publickey

Host gitlab.com
    HostName gitlab.com
    User git
    IdentityFile ~/.ssh/gitlab_rsa

Host gitee.com
    HostName gitee.com
    User git
    IdentityFile ~/.ssh/gitee_rsa