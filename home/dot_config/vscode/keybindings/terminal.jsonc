    "key": "ctrl+j",
    "command": "workbench.action.quickOpenNavigateNextInTerminalPicker",
    "when": "inTerminalPicker"
  },
  {
    "key": "ctrl+k",
    "command": "workbench.action.quickOpenNavigatePreviousInTerminalPicker",
    "when": "inTerminalPicker"
  }, */
