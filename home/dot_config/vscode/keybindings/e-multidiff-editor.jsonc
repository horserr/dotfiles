[
  {
    "key": "escape",
    "command": "runCommands",
    "args": {
      "commands": [
        "vspacecode.space",
        { "command": "whichkey.triggerKey", "args": "/" },
        { "command": "whichkey.triggerKey", "args": "c" },
        { "command": "whichkey.triggerKey", "args": "m" }
      ]
    },
    "when": "activeEditor == 'multiDiffEditor' && editorTextFocus && (vim.mode =~ /normal/i) && !editorHasMultipleSelections && !editorHasSelection"
  }
]
