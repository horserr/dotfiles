  },
  {
    "command": "-search.action.searchWithAI",
    "key": "ctrl+i",
    "when": "hasAIResultProviderKey && searchViewletFocus"
  },
  {
    "command": "workbench.action.files.newUntitledFile",
    "key": "ctrl+k n"
  },
  {
    "command": "-workbench.action.showCommands",
