  },
  {
    "command": "-markdown.extension.editing.toggleBold",
    "key": "shift+alt+f"
  },
  {
    "command": "-magit.discard-at-point",
    "key": "x"
  },
  {
    "command": "-magit.reverse-at-point",
    "key": "v"
  },
  {
