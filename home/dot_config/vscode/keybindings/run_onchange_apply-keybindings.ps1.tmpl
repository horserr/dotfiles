{{- /* 1) 源目录：keybindings 分片目录 */ -}}
{{- $partsDir := joinPath .chezmoi.sourceDir "dot_config/vscode/keybindings" -}}

{{- /* 2) 触发哈希：任一分片变化都会触发 run_onchange */ -}}
{{- $content := "" -}}
{{- range (glob (joinPath $partsDir "*.json*")) -}}
	{{- $content = print $content (include .) -}}
{{- end -}}

# VSCode Keybindings Hash: {{ $content | sha256sum }}

Set-StrictMode -Version Latest
$ErrorActionPreference = "Stop"

$targetFile = Join-Path $env:APPDATA "Code\User\keybindings.json"
$partsDir = "{{ $partsDir }}"
$helperScript = '{{ joinPath .chezmoi.sourceDir "dot_config/vscode/scripts/merge-vscode-jsonc-fragments.ps1" }}'

Write-Host "检测到 VSCode keybindings 分片变动，正在生成：$targetFile"

if (!(Test-Path $helperScript)) {
		throw "公共合并脚本不存在: $helperScript"
}

. $helperScript

Merge-VSCodeJsoncFragments -PartsDir $partsDir -TargetFile $targetFile -Mode Array -GeneratorName "run_onchange_apply-keybindings.ps1.tmpl" -FragmentKind "keybindings"
