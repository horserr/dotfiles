{
  "$schema": "vscode://schemas/settings/user",
  "chat.agent.maxRequests": 200,
  "chat.agent.thinking.collapsedTools": "withThinking",
  "chat.agent.thinking.phrases": {
    "mode": "append",
    "phrases": [
      "Bribing the hamster",
      "Reticulating splines",
      "Untangling the spaghetti"
    ]
  },
  "chat.disableAIFeatures": false,
  // copilot chat settings
  "chat.editor.fontSize": 17,
  "chat.editor.lineHeight": 1.4,
  "chat.editor.wordWrap": "on",
  "chat.edits2.enabled": true,
  "chat.fontFamily": "LXGW Wenkai",
  "chat.fontSize": 17,
  "chat.mcp.discovery.enabled": {
    "claude-desktop": true,
    "cursor-global": true,
    "cursor-workspace": true,
    "windsurf": true
  },
  "chat.mcp.gallery.enabled": true,
  "chat.notifyWindowOnConfirmation": "windowNotFocused",
  "chat.notifyWindowOnResponseReceived": "windowNotFocused",
  "chat.renderRelatedFiles": true,
  "chat.tools.terminal.sandbox.enabled": false,
  "chat.viewProgressBadge.enabled": true,
  "chat.viewSessions.orientation": "stacked",
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.chat.copilotMemory.enabled": true,
  "github.copilot.chat.editor.temporalContext.enabled": true,
  "github.copilot.chat.edits.temporalContext.enabled": true,
  "github.copilot.chat.generateTests.codeLens": true,
  "github.copilot.chat.languageContext.fix.typescript.enabled": true,
  "github.copilot.chat.languageContext.inline.typescript.enabled": true,
  "github.copilot.chat.languageContext.typescript.enabled": true,
  // "python.terminal.activateEnvInCurrentTerminal": true,
  "github.copilot.chat.notebook.enhancedNextEditSuggestions.enabled": true,
  "github.copilot.chat.scopeSelection": true,
  "github.copilot.chat.tools.memory.enabled": true,
  "github.copilot.enable": {
    "*": false,
    "ahk2": true,
    "powershell": true
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.nextEditSuggestions.extendedRange": true,
  "github.copilot.nextEditSuggestions.fixes": true,
  "inlineChat.affordance": "editor",
  "inlineChat.enableV2": true,
  "inlineChat.finishOnType": true,
  "inlineChat.renderMode": "hover"
}
