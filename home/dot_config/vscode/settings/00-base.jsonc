    "vim.maxmapdepth",
    "vim.mouseSelectionGoesIntoVisualMode",
    "vim.neovimConfigPath",
    "vim.neovimUseConfigFile",
    "vim.overrideCopy",
    "vim.replaceWithRegister",
    "vim.report",
    "vim.scroll",
    "vim.searchHighlightColor",
