    "vim.easymotionMarkerForegroundColorTwoCharSecond",
    "vim.foldfix",
    "vim.gdefault",
    "vim.handleKeys",
    "vim.highlightedyank.color",
    "vim.highlightedyank.duration",
    "vim.highlightedyank.enable",
    "vim.highlightedyank.textColor",
    "vim.history",
    "vim.hlsearch",
    "vim.ignorecase",
    "vim.inccommand",
    "vim.incsearch",
