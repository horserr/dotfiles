{
  /*   terminal.integrated.suggest.quickSuggestions : show automatically depending on the content of the command line, as opposed to manually via Ctrl+Space.
  terminal.integrated.suggest.suggestOnTriggerCharacters : show automatically after a "trigger character" such as - or /.
  terminal.integrated.suggest.runOnEnter : optionally run the command when Enter is used (not Tab).
  terminal.integrated.suggest.windowsExecutableExtensions : the list of extensions that are treated as executables on Windows.
  terminal.integrated.suggest.providers : provides the ability to disable specific providers, for example extensions may contribute completions you don't want.
  terminal.integrated.suggest.showStatusBar : show the status bar at the bottom of the IntelliSense popup.
  terminal.integrated.suggest.cdPath : enable $CDPATH integration.
  terminal.integrated.suggest.inlineSuggestion : integrate with shell "ghost text" and how to present it.
  terminal.integrated.suggest.upArrowNavigatesHistory : send up arrow to the shell instead of browsing completions, this is particularly useful on zsh where you can filter and then press up to do a history search with that prefix.
  terminal.integrated.suggest.selectionMode : how the Intellisense popup is focused which determines what Enter and Tab do.
  terminal.integrated.suggest.insertTrailingSpace : insert a trailing space and re-trigger completions after accepting. */

  "terminal.external.windowsExec": "wt",
  // UPLIFTING 自动识别 scheme 并允许点击
  "terminal.integrated.allowedLinkSchemes": [
    "file",
    "http",
    "https",
    "mailto",
    "vscode",
    "vscode-insiders"
  ],
  // UPLIFTING 按住 alt 并 click 可以移动光标
  "terminal.integrated.altClickMovesCursor": true,
  // UPLIFTING 自动输入
  "terminal.integrated.autoReplies": {},
  "terminal.integrated.bellDuration": 1000,

  // default behavior is that terminal intercepts all keybindins. Commands in this list surpress this behavior
  // link: https://code.visualstudio.com/docs/terminal/advanced#_keyboard-shortcuts-and-the-shell
  "terminal.integrated.commandsToSkipShell": [
    "vspacecode.space",
    "whichkey.show",
    "editor.action.accessibleView",
    "workbench.action.terminal.fontZoomIn",
    "workbench.action.terminal.fontZoomOut",
    "workbench.action.terminal.fontZoomReset"
  ],
  "terminal.integrated.sendKeybindingsToShell": false,
  "terminal.integrated.allowChords": false,
  "terminal.integrated.allowMnemonics": false,

  // "terminal.integrated.commandsToSkipShell": ["matlab.interrupt"],
  "terminal.integrated.confirmOnExit": "hasChildProcesses",
  "terminal.integrated.confirmOnKill": "editor",
  "terminal.integrated.showExitAlert": true,

  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorStyleInactive": "outline",
  "terminal.integrated.cursorWidth": 6,
  "terminal.integrated.cwd": "",
  // UPLIFTING terminal 默认在 pane 而非 editor
  "terminal.integrated.defaultLocation": "view",
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  // UPLIFTING 自动设置 $LANG
  "terminal.integrated.detectLocale": "on",
  // UPLIFTING
  "terminal.integrated.enableFileLinks": "on",
  "terminal.integrated.enableImages": true,
  // UPLIFTING 使用 kitty 协议
  "terminal.integrated.enableKittyKeyboardProtocol": true,
  // UPLIFTING
  "terminal.integrated.enableNotifications": true,
  "terminal.integrated.enableVisualBell": true,
  "terminal.integrated.enableWin32InputMode": true,
  // UPLIFTING
  "terminal.integrated.env.linux": {},
  "terminal.integrated.env.windows": {},
  // SIGNIFICANT
  "terminal.integrated.environmentChangesRelaunch": true,
  // UPLIFTING alt 并 scroll 可以快速翻页
  "terminal.integrated.fastScrollSensitivity": 5,
  // UPLIFTING run selected text in terminal 之后不将 focus 移动到 terminal 中
  "terminal.integrated.focusAfterRun": "none",
  "terminal.integrated.fontFamily": "CaskaydiaCove Nerd Font",
  "terminal.integrated.fontLigatures.enabled": true,
  "terminal.integrated.fontLigatures.featureSettings": "\"calt\" on, \"liga\" on, \"ss01\", \"ss02\"",
  "terminal.integrated.fontSize": 17,
  "terminal.integrated.fontWeight": "normal",
  // UPLIFTING 当没有需要恢复的 terminal 时自动关闭 terminal pane
  "terminal.integrated.hideOnStartup": "whenEmpty",
  "terminal.integrated.ignoreProcessNames": [
    "starship",
    "oh-my-posh",
    "oh-my-fish"
  ],
  // ?
  "terminal.integrated.initialHint": true,
  "terminal.integrated.lineHeight": 1.2,
  "terminal.integrated.localEchoEnabled": "auto",
  "terminal.integrated.localEchoLatencyThreshold": 30,
  "terminal.integrated.localEchoStyle": "underlined",
  // UPLIFTING 先显示打出来的字符，而不是先传输再显示，提升响应速度，但是避免复杂 TUI 应用
  "terminal.integrated.localEchoExcludePrograms": [
    "vim",
    "vi",
    "nano",
    "neovim",
    "nvim",
    "tmux",
    "zellij"
  ],
  "terminal.integrated.middleClickBehavior": "default",
  // UPLIFTING 自动调整对比度
  "terminal.integrated.minimumContrastRatio": 4.5,
  // 不允许使用鼠标滚轮缩放
  "terminal.integrated.mouseWheelZoom": false,
  // 恢复 terminal 的时机
  "terminal.integrated.persistentSessionReviveProcess": "onExitAndWindowClose",
  "terminal.integrated.persistentSessionScrollback": 50,
  // don't display wsl profile
  "terminal.integrated.useWslProfiles": false,
  "terminal.integrated.profiles.windows": {
    "Command Prompt": {
      "icon": "terminal-cmd",
      "path": "cmd"
    },
    "Git Bash": {
      "source": "Git Bash"
    },
    "PowerShell": {
      "icon": "terminal-powershell",
      "source": "PowerShell"
    },
    "WSL default": {
      "path": "wsl"
    },
    "Native PowerShell": {
      "path": "powershell",
      "icon": "terminal-secure"
    }
  },
  "terminal.integrated.rightClickBehavior": "default",
  "terminal.integrated.scrollback": 1000,
  "terminal.integrated.shellIntegration.decorationsEnabled": "both",
  "terminal.integrated.shellIntegration.environmentReporting": true,
  "terminal.integrated.shellIntegration.history": 40,
  "terminal.integrated.showLinkHover": false,
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.splitCwd": "inherited",
  // disable sticky scroll
  "terminal.integrated.stickyScroll.enabled": false,
  // "terminal.integrated.stickyScroll.ignoredCommands": [
  //   "clear",
  //   "cls",
  //   "clear-host",
  //   "copilot",
  //   "claude",
  //   "codex",
  //   "gemini",
  //   "git",
  //   "ssh",
  //   "less",
  //   "tmux",
  //   "ls"
  // ],
  // "terminal.integrated.stickyScroll.maxLineCount": 2,
  "terminal.integrated.suggest.selectionMode": "partial",
  "terminal.integrated.suggest.cdPath": "relative",
  "terminal.integrated.suggest.inlineSuggestion": "alwaysOnTopExceptExactMatch",
  // ?
  "terminal.integrated.suggest.providers": {
    "lsp": true,
    "vscode.terminal-suggest": true
  },
  "terminal.integrated.suggest.quickSuggestions": {
    "arguments": "on",
    "commands": "on",
    "unknown": "on"
  },
  "terminal.integrated.suggest.suggestOnTriggerCharacters": true,
  "terminal.integrated.tabs.defaultColor": "terminal.ansiMagenta",
  "terminal.integrated.tabs.defaultIcon": "azure-devops",
  "terminal.integrated.tabs.description": "${task}${separator}${local}${separator}${cwdFolder}",
  "terminal.integrated.tabs.focusMode": "doubleClick",
  "terminal.integrated.tabs.hideCondition": "singleGroup",
  "terminal.integrated.tabs.location": "left",
  "terminal.integrated.tabs.separator": " 🫠 ",
  "terminal.integrated.tabs.showActions": "always",
  "terminal.integrated.tabs.showActiveTerminal": "singleTerminalOrNarrow",
  "terminal.integrated.tabs.title": "${sequence}",
  "terminal.integrated.tabStopWidth": 2,
  "terminal.integrated.textBlinking": true,
  "terminal.sourceControlRepositoriesKind": "integrated"
}
