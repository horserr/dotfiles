          },
          {
            "key": "C",
            "name": "Clear all inline results",
            "icon": "clear-all",
            "type": "command",
            "command": "language-julia.clearAllInlineResults"
          },
          {
            "key": "K",
            "name": "Clear all inline results in editor",
            "icon": "clear-all",
            "type": "command",
            "command": "language-julia.clearAllInlineResultsInEditor"
          }
        ]
      },
      {
        "key": "e",
