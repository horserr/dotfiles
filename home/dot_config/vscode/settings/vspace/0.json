  },
  {
    "key": "0",
    "name": "Focus on files explorer",
    "icon": "list-tree",
    "type": "command",
    "command": "workbench.files.action.focusFilesExplorer"
  },
  {
    "key": ";",
    "name": "Toggle comment",
    "icon": "comment",
    "type": "command",
