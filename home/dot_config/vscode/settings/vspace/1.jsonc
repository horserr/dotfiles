[
  {
    "key": " ",
    "name": "Commands",
    "icon": "rocket",
    "type": "command",
    "command": "workbench.action.showCommands"
  },
  // tab repeat recent command
  {
    "key": "\t",
    "name": "repeat recent command",
    "icon": "redo",
    "type": "command",
    "commands":"whichkey.repeatRecent"
  },
  {
    "key": "*",
    "name": "focus editor",
    "icon": "search",
    "type": "command",
    "command": "runCommands",
    "args": {
      "commands": [
        "workbench.action.focusActiveEditorGroup",
        {
          "command": "cursorMove",
          "args": {
            "to": "viewPortIfOutside"
          }
        }
      ]
    }
  },
