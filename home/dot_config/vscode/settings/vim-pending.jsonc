{
  "vim.operatorPendingModeKeyBindingsNonRecursive": [
    {
      "after": ["g", "$"],
      "before": ["L"]
    },
    {
      "after": ["g", "^"],
      "before": ["H"]
    },
    {
      // camelCaseMotion
      "before": ["w"],
      "after": ["<leader>", "w"]
      // "commands": ["cursorWordPartRight"]
    },
    {
      // camelCaseMotion
      "before": ["b"],
      "after": ["<leader>", "b"]
      // "commands": ["cursorWordPartLeft"]
    }
  ]
}
