  "searchWebDefaultQueryUrl": "https://www.duckduckgo.com/search?q=%s",
  "showAdminShield": true,
  "showTabsFullscreen": false,
  "showTabsInTitlebar": true,
  "showTerminalTitleInTitlebar": true,
  "snapToGridOnResize": false,
  "startupActions": "", // SIGNIFICANT
  "tabSwitcherMode": "inOrder",
  "tabWidthMode": "compact",
  "theme": "system",
  "themes": [
    {
      "name": "rose-pine",
      "tab": {
        "background": "#191724FF",
        "iconStyle": "default",
        "showCloseButton": "always",
        "unfocusedBackground": null
      },
      "tabRow": {
        "background": "#26233AFF",
        "unfocusedBackground": "#908CAAFF"
      },
      "window": {
        "applicationTheme": "dark",
        "experimental.rainbowFrame": false,
        "frame": null,
        "unfocusedFrame": null,
        "useMica": false
      }
    },
    {
      "name": "rose-pine-dawn",
      "tab": {
        "background": "#FAF4EDFF",
        "iconStyle": "default",
        "showCloseButton": "always",
        "unfocusedBackground": null
      },
      "tabRow": {
        "background": "#F2E9E1FF",
        "unfocusedBackground": "#797593FF"
      },
      "window": {
        "applicationTheme": "light",
        "experimental.rainbowFrame": false,
        "frame": null,
        "unfocusedFrame": null,
        "useMica": false
      }
    },
    {
      "name": "rose-pine-moon",
      "tab": {
        "background": "#232136FF",
        "iconStyle": "default",
        "showCloseButton": "always",
        "unfocusedBackground": null
      },
      "tabRow": {
