        "unfocusedBackground": "#908CAAFF"
      },
      "window": {
        "applicationTheme": "dark",
        "experimental.rainbowFrame": false,
        "frame": null,
        "unfocusedFrame": null,
        "useMica": false
      }
    }
  ],
  "trimBlockSelection": true, // alt-pressed selection
  "trimPaste": true,
  "useAcrylicInTabRow": true,
  "warning.confirmCloseAllTabs": false, // don't show close confirm
  "warning.largePaste": true,
  "warning.multiLinePaste": true,
  "windowingBehavior": "useExisting",
  "wordDelimiters": " .\\()\"'-:,.;<>~!@#$%^&*|+=[]{}~?│，。？（）【】！“”‘’《》"
}
