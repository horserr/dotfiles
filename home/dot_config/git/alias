# code: language=ini
[alias]
	repo = clone --depth 1 --filter=blob:none --sparse
	shallow-repo = clone --depth
	partial-repo = clone --filter=blob:none --no-checkout
	set-partial = "!f() { git config remote.$1.partialclonefilter blob:none; }; f"
	w = worktree
	# used for worktree sparse checkout
	wemp = worktree add --no-checkout
	# sparce checkout is similar to **view**
	v = sparse-checkout
	vdown = sparse-checkout disable

	sub = submodule
	# empty submodule without clone
	subfor = submodule foreach
	subemp = submodule add --no-checkout
	subdiff = "!git diff && git submodule foreach 'git diff'"
	subpush = push --recurse-submodules=on-demand
	subupdate = submodule update --remote --merge

	# log
	l = log --pretty=oneline --name-status --abbrev-commit --no-merges
	la = log --all --pretty=oneline --graph --abbrev-commit --no-merges
	# log filter
	lf = log --pretty=oneline --name-status --abbrev-commit --no-merges --follow --diff-filter
	lfollow = log --pretty=oneline --name-status --abbrev-commit --follow
	# log conflicted commit messages
	lm = log --oneline --left-right --merge
	# REALLY usefule to find conflict commits
	lmm = log --oneline --left-right --merge --patch
	# log bifurcated(fork) commits
	lfork = log --oneline --left-right HEAD...MERGE_HEAD

	# git grep
  g = grep --show-function
  gcount = grep --count
	# log pickaxe
	p = log --stat --pretty=oneline --abbrev-commit -S
	pR = log --reverse --pretty=oneline --abbrev-commit -S
	pp = log --no-merges --stat --regexp-ignore-case -G
	# log line: REALLY useful and amazing
  # usage: git log -L :git_deflate_bound:zlib.c
	h = log --oneline --no-patch -L
	hh = log --oneline -L

	# show and status
  # enhanced git status
		# s = status --short --branch
  # show git status with --short --branch options
	# but simplify file names
	# displaying the full path only when having duplicate file names
	# use less as pager and support color mode
	s = "!f() { \
		C_RED=$(tput setaf 1); \
		C_GRN=$(tput setaf 2); \
		C_YLW=$(tput setaf 3); \
		C_B=$(tput bold); \
		C_RST=$(tput sgr0); \
		git status -s -b --porcelain \
		| awk -v r=\"$C_RED\" -v g=\"$C_GRN\" -v y=\"$C_YLW\" -v b=\"$C_B\" -v rst=\"$C_RST\" '{ \
			if (/^##/) { \
				match($0, /^## [^.]+/); \
				branch_part = substr($0, RSTART, RLENGTH); \
				rest_part = substr($0, RSTART + RLENGTH); \
				print b branch_part rst y rest_part rst; \
				next; \
			} \
			\
			code = substr($0, 1, 2); \
			full_path = substr($0, 4); \
			\
			clean_path = full_path; \
			sub(/.* -> /, \"\", clean_path); \
			match(clean_path, /[^/]+$/); \
			base_name = substr(clean_path, RSTART, RLENGTH); \
			\
			c1 = substr(code, 1, 1); \
			c2 = substr(code, 2, 1); \
			\
			color1 = (c1==\"M\"||c1==\"A\"||c1==\"D\"||c1==\"R\"||c1==\"C\") ? g : \"\"; \
			color2 = (c2==\"M\"||c2==\"D\") ? r : (c2==\"?\"||c1==\"?\") ? r : \"\"; \
			\
			fmt_code = color1 c1 rst color2 c2 rst; \
			\
			status_code[NR] = fmt_code; \
			paths[NR] = full_path; \
			files[NR] = base_name; \
			count[base_name]++; \
		} END { \
			for (i = 1; i <= NR; i++) { \
				if (!paths[i]) continue; \
				\
				if (count[files[i]] > 1) { \
					display = paths[i]; \
				} else { \
					if (paths[i] ~ / -> /) { \
						split(paths[i], parts, \" -> \"); \
						display = parts[1] \" -> \" files[i]; \
					} else { \
						display = files[i]; \
					} \
				} \
				print status_code[i] \" \" display; \
			} \
		}' | less -RFX; }; f"

	sh = show --pretty=oneline --stat
	sd = diff --stat --ignore-space-change
	# what to be committed: diff between staged and the repo
	sdd = diff --stat --ignore-space-change --staged
	# show progress
	spro = describe --tags --always
	# show tag: followed by standard shell regex
	stag = tag -l
	# show base
	sbase  = "!f() { git show --color :1:$1; }; f"
	# show ours
	sours = "!f() { git show --color :2:$1; }; f"
	# show theirs
	stheirs = "!f() { git show --color :3:$1; }; f"
	sb = branch --verbose
	sbb = branch --verbose --all
	# show upstream
	supstream = rev-parse --abbrev-ref @{upstream}
	# show merged branches
	sbmerge = branch --merged

	a = add --update
	# update those files that already staged
	as = "!git diff --name-only --cached | git add --pathspec-from-file=-"
  au = add --intent-to-add .
	aa = add .
	aaa = add --all

	b = blame -C -L

	c = commit
	cc = commit -m
	ca = commit --all
	cam = commit --amend
	cne = commit --amend --no-edit
	cemp = commit --allow-empty
	cfix = commit --fixup
	csquash = commit --squash

	# what modified: diff between working dir and staged
	d = diff --ignore-space-change
	dw = diff --word--diff --ignore-space-change
	# what to be committed: diff between staged and the repo
	dd = diff --ignore-space-change --staged
	# diff between
	ddd = diff --ignore-space-change HEAD
	dt = difftool
	# 对比两边的原始版本
	dours = diff --ours
	dtheirs = diff --theirs
	# 在还没开始改代码前，搞清楚对方的分支到底动了哪些文件
	dfork = diff HEAD...MERGE_HEAD

	# clean untracked files
	x = clean --dry-run
	xx = clean --force
	# clean ignored files or folders
	xi = clean -X --dry-run
	xxi = clean -X --force
	# clean untracked directories
	xd = clean -d --dry-run
	xxd = clean -d --force

	# interactive add/stage
  ia = add --interactive
	iaa = add --patch
  # Interactive rebase with the given number of latest commits.
	ir = rebase --interactive
	# useful for orphan branch
	irroot = rebase --interactive --root
	# 1. 剪断侧枝， 2. 快速删除中间某些提交， 3.
	ironto = rebase --interactive --onto
	# interactive unstage
	iu = reset --patch
	# interactive stash
	is = stash --patch
	ik = stash --patch
	# Note: do not use: checkout --patch
	# interactivly clean ignored files or folders
	ix = clean -X --interactive

	# jump = switch
	j = switch
	jc = switch --create
	jd = switch --detach
	jorphan = switch --orphan

  # k for keep, the sysnonym of stash
	k = stash
	# only keep staged files
	ks = stash --staged
	# create a new branch from stash
	kb = stash branch
	# keep index, equivalent to stash(all untracked files, including staged files) and leave staged files in staged
	ki = stash --keep-index
	kk = stash --include-untracked # shortfor -u
	# all files, including ignored files, such as those files in dist/ node_modules. not recommend to use
	kkk = stash --all

  # filter
	# show conflict files
	f = diff --name-only --diff-filter
	# filter then interactive add
	# output the filter list into vim
	# then edit list and pass it to git add
	# use :cq to quit vim when things go wrong
	fi = "!f(){ \
		git diff --name-only --diff-filter=\"$1\" > /tmp/git-add-list && \
		vim /tmp/git-add-list && \
		git add --pathspec-from-file=/tmp/git-add-list; \
		rm -f /tmp/git-add-list; \
	}; f \"$1\""
	# filter modified
	ffm = diff --name-only --diff-filter=M
	# filter conflict
	ffc = diff --name-only --diff-filter=U
	# filter untracked
  ffu = ls-files --others --exclude-standard
	# filter ignored
	ffignore = check-ignore
	# filter those files should be ignored but tracked
	# can be then passed to git restore --cached or filter-repo
	ffwrong = ls-files --ignored --cached --exclude-standard
	# use deduplicate to remove conflict files with same name but different numbering, such as 1 2 3
	ffconflict = ls-file --unmerged --deduplicate

	m = merge -Xignore-space-change
	# use ours
	mours = merge -Xours
	re-merge = restore --conflict=merge

	unstage = restore --staged
	alias = config --get-regexp alias

	lost-found = fsck --lost-found
	covert = update-index --skip-worktree
	overt = update-index --no-skip-worktree
	ls-covert = "!f() { git ls-files -v | grep '^S';}; f"
	freeze = update-index --assume-unchanged
	unfreeze = update-index --no-assume-unchanged
	ls-freeze = "!f() { git ls-files -v | grep '^h';}; f"
	# todo
	# git rebase (--continue|--skip|--abort|--quit|--edit-todo|--show-current-patch)
	#  git rebase --show-current-patch, or its equivalent git show REBASE_HEAD
	# continue = rebase --continue
	# abort = rebase --abort

	pick = cherry-pick

	depth = fetch --depth
	deepen = fetch --deepen
	shallow-since = fetch --shallow-since
	unshallow = fetch --unshallow

	conf = config --global --edit
	confl = config --local --edit
	confsub = "!f() { \
			MODFILE=\"$(git rev-parse --show-toplevel)/.gitmodules\"; \
			if [ -f \"$MODFILE\" ]; then \
				git config --edit --file \"$MODFILE\"; \
			else \
				echo \"❌ .gitmodules 文件不存在，跳过编辑\"; \
			fi; \
		}; f"

  # edit sparse-checkout file, and reapply sparse-checkout after editing
	conf-sparse = "!f() { \
			if [ \"$(git config --get core.sparseCheckout)\" != \"true\" ]; then \
					echo \"Error: Sparse-checkout is not enabled in this repository.\"; \
					echo \"Run 'git sparse-checkout init' first.\"; \
			else \
				$(git var GIT_EDITOR) \"$(git rev-parse --git-path info/sparse-checkout)\" && git sparse-checkout reapply; \
			fi; \
	}; f"

 # test whether the given files is deemed as executable in git
	is-x = "!f() { \
		if [ -z \"$1\" ]; then echo \"Usage: git is-x <file_path>\"; return 1; fi; \
		res=$(git ls-files -s \"$1\"); \
		if [ -z \"$res\" ]; then echo \"File not tracked by git.\"; return 1; fi; \
		if echo \"$res\" | grep -q '^100755'; then echo \"🟢 Executable (100755)\"; \
		else echo \"🔴 Not Executable (100644)\"; fi; \
	}; f"
	# turn a file to executable in git
	turn-x = update-index --chmod=+x

	whoami = config user.email

	# plumbing commands
	cat = cat-file -p
	# -r: recursive, -t: tree node, -l: show size
	lstree = ls-tree -r -t -l --abbrev # --name-only
	# list Index
	lsfile = ls-files
	mergefile = merge-file -p # ours common theirs

	# root = "!cd $(git rev-parse --show-toplevel)"
	root = rev-parse --show-toplevel
	dir = rev-parse --show-prefix
	is-shallow = rev-parse --is-shallow-repository
	is-sparse = "!f() { [ \"$(git config --get core.sparseCheckout)\" = \"true\" ] && echo \"True\" || echo \"False\"; }; f"
	test-date = rev-parse --since
	print-missing = rev-list --objects --missing=print

	# GIT_TRACE=true
	# GIT_TRACE_SETUP =true
	# GIT_TRACE_PERFORMANCE=true

	# Note: the difference between ls-tree and ls-files:
		# ls-tree is applied to a specific commit or tree object
		# ls-files is applied to the Index(the staged files)

	memo = "!f() { \
		local H='\\033[1;34m' G='\\033[1;32m' R='\\033[1;31m' Y='\\033[1;33m' M='\\033[1;35m' C='\\033[1;36m' W='\\033[1;37m' X='\\033[0m'; \
		printf '%b%-60s%b\\n' \"$H\" '+----------+------------------------------------------------+' \"$X\"; \
		printf '%b  %-8s    %-48s%b\\n' \"$H\" 'Letter' 'Meaning' \"$X\"; \
		printf '%b%-60s%b\\n' \"$H\" '+----------+------------------------------------------------+' \"$X\"; \
		printf '  %b%-8s%b    %-48s\\n' \"$G\" 'A' \"$X\" 'Added'; \
		printf '  %b%-8s%b    %-48s\\n' \"$G\" 'C' \"$X\" 'Copied'; \
		printf '  %b%-8s%b    %-48s\\n' \"$R\" 'D' \"$X\" 'Deleted'; \
		printf '  %b%-8s%b    %-48s\\n' \"$Y\" 'M' \"$X\" 'Modified'; \
		printf '  %b%-8s%b    %-48s\\n' \"$M\" 'R' \"$X\" 'Renamed'; \
		printf '  %b%-8s%b    %-48s\\n' \"$C\" 'T' \"$X\" 'Type changed (File/Symlink/Submodule)'; \
		printf '  %b%-8s%b    %-48s\\n' \"$R\" 'U' \"$X\" 'Unmerged (Conflict)'; \
		printf '  %b%-8s%b    %-48s\\n' \"$W\" 'X' \"$X\" 'Unknown'; \
		printf '  %b%-8s%b    %-48s\\n' \"$R\" 'B' \"$X\" 'Broken (Pairing)'; \
		printf '%b%-60s%b\\n' \"$H\" '+----------+------------------------------------------------+' \"$X\"; \
		printf '%b  1. can combine  2. * for (All-or-none)                   %b\\n' \"$C\" \"$X\"; \
		printf '%b     3. lowercase for inverse selection                    %b\\n' \"$C\" \"$X\"; \
		printf '%b%-60s%b\\n' \"$H\" '+----------+------------------------------------------------+' \"$X\"; \
	}; f"

	# Find branches containing commit
	fb = "!f() { git branch -a --contains $1; }; f"

	# Find tags containing commit
	ft = "!f() { git describe --always --contains $1; }; f"

  # git log origin/main..HEAD  # show what is about to push
  # git log origin/main..      # for simplicity
	# show remote <name>
	# git fetch origin --prune/p <branch>
	# git push origin --delete <branch>
	# git filter-repo
	# git archive

